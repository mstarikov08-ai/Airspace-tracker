# ─────────────────────────────────────────────────────────────────────────────
# Airspace NOTAM Tracker — configuration template
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# OPTIONAL — post alerts to a channel (numeric ID or @channel_username)
# The bot must be an admin of the channel with "Post Messages" permission.
TELEGRAM_CHANNEL_ID=

# OPTIONAL — path to the SQLite database (default: notams.db in current dir)
DB_PATH=notams.db

# OPTIONAL — how often to refresh NOTAMs in minutes (default: 15)
POLL_INTERVAL_MINUTES=15
